{
  "_comment": "qwen-pilot configuration — copy to .qwen-pilot/qwen-pilot.json",

  "models": {
    "_comment": "Model identifiers for each performance tier",
    "high": "qwen3.5-plus",
    "balanced": "qwen3-coder-plus",
    "fast": "qwen3-coder-next"
  },

  "harness": {
    "_comment": "Settings for the interactive harness session",
    "defaultTier": "balanced",
    "sandboxMode": "relaxed",
    "maxTokens": 8192,
    "temperature": 0.7,
    "contextWindow": 262144
  },

  "team": {
    "_comment": "Multi-agent team mode configuration",
    "maxWorkers": 4,
    "heartbeatIntervalMs": 5000,
    "taskTimeoutMs": 300000,
    "sessionPrefix": "qp"
  },

  "stateDir": ".qwen-pilot",
  "promptsDir": "prompts",
  "workflowsDir": "workflows",
  "hooksEnabled": true
}

{
  "name": "qwen-pilot",
  "version": "1.0.0",
  "description": "Multi-agent orchestration harness for Qwen CLI — prompts, workflows, and team coordination",
  "author": "Doeon Kim",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "qp": "dist/cli/index.js",
    "qwen-pilot": "dist/cli/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "prompts",
    "workflows",
    "AGENTS.md",
    "README.md",
    "README.ko.md",
    "Install-Mac.command",
    "Install-Windows.bat",
    "Install-Linux.sh"
  ],
  "scripts": {
    "prebuild": "rm -f tsconfig.tsbuildinfo",
    "build": "tsc",
    "dev": "tsc --watch",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepublishOnly": "npm run clean && npm run build",
    "verify": "npm run lint && npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "commander": "^14.0.3",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "keywords": [
    "qwen",
    "alibaba",
    "cli",
    "multi-agent",
    "orchestration",
    "ai",
    "llm",
    "workflow",
    "prompt",
    "agent",
    "mcp",
    "automation",
    "tmux"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/KIM3310/qwen-pilot"
  },
  "bugs": {
    "url": "https://github.com/KIM3310/qwen-pilot/issues"
  },
  "homepage": "https://github.com/KIM3310/qwen-pilot#readme"
}
